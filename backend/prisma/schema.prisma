generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SUPERADMIN
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String?
  password          String?
  role              Role               @default(USER)
  provider          String?
  providerId        String?
  refreshToken      String?
  avatar            Json?
  quizzes           Quiz[]
  questionBanks     QuestionBank[]
  gameHistory       GamePlayer[]       @relation("UserGameHistory")
  collections       Collection[]       @relation("UserCollections")
  collectionMembers CollectionMember[]
  savedCollections  SavedCollection[]
  createdAt         DateTime           @default(now())
}

model Quiz {
  id          String     @id @default(cuid())
  title       String
  description String?
  ownerId     String
  status      QuizStatus @default(DRAFT)
  type        QuizType   @default(LIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id])

  questions QuizQuestion[]

  // Existing relations to preserve if possible
  isFavorite   Boolean       @default(false)
  gameSessions GameSession[] @relation("QuizToGameSessions")

  // Relations for Collections (legacy but keeping for now to avoid breaking changes)
  templateItems CollectionItem[] @relation("QuizTemplate")
  bankItems     CollectionItem[] @relation("QuestionBank")
}

enum QuizStatus {
  DRAFT
  PUBLISHED
}

enum QuizType {
  LIVE
  TEMPLATE
}

model Question {
  id         String       @id @default(cuid())
  content    String
  type       QuestionType
  difficulty Difficulty?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers Answer[]

  bankItems QuestionBankItem[]
  quizItems QuizQuestion[]
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Answer {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuestionBank {
  id          String  @id @default(cuid())
  name        String
  description String?
  ownerId     String

  visibility BankVisibility @default(PRIVATE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id])

  items QuestionBankItem[]
}

enum BankVisibility {
  PRIVATE
  SHARED
  PUBLIC
}

model QuestionBankItem {
  id         String @id @default(cuid())
  bankId     String
  questionId String

  bank     QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  question Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([bankId, questionId])
}

model QuizQuestion {
  id         String @id @default(cuid())
  quizId     String
  questionId String

  sourceType   QuestionSource
  sourceBankId String?

  position Int

  quiz     Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionId])
}

enum QuestionSource {
  MANUAL
  BANK_COPY
  BANK_REFERENCE
  TEMPLATE
}

model GameSession {
  id             String       @id @default(uuid())
  hostId         String?
  roomCode       String? // added for re-entering lobby
  quizId         String?
  quiz           Quiz?        @relation("QuizToGameSessions", fields: [quizId], references: [id], onDelete: SetNull)
  title          String // snapshot quiz title
  questions      Json // snapshot seluruh question + options
  totalQuestions Int
  createdAt      DateTime     @default(now())
  finishedAt     DateTime?
  status         GameStatus   @default(WAITING)
  players        GamePlayer[] @relation("SessionToPlayers")

  @@index([quizId])
}

enum GameStatus {
  WAITING
  STARTED
  FINISHED
  ABORTED
}

model GamePlayer {
  id        String       @id @default(uuid())
  sessionId String
  session   GameSession  @relation("SessionToPlayers", fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?        @relation("UserGameHistory", fields: [userId], references: [id], onDelete: SetNull)
  nickname  String
  score     Int
  joinedAt  DateTime     @default(now())
  answers   GameAnswer[] @relation("PlayerToAnswers")

  @@unique([sessionId, nickname])
  @@index([sessionId])
  @@index([userId])
}

model GameAnswer {
  id               String     @id @default(uuid())
  playerId         String
  player           GamePlayer @relation("PlayerToAnswers", fields: [playerId], references: [id], onDelete: Cascade)
  questionIndex    Int
  selectedOptionId String
  isCorrect        Boolean
  responseTime     Int

  @@index([playerId])
}

enum CollectionVisibility {
  PRIVATE
  PUBLIC
}

enum CollectionItemType {
  QUIZ_TEMPLATE
  QUESTION_BANK
}

enum CollectionRole {
  OWNER
  EDITOR
  VIEWER
}

enum CollectionMemberStatus {
  PENDING_INVITE
  PENDING_REQUEST
  ACCEPTED
}

model Collection {
  id          String               @id @default(uuid())
  title       String
  description String?
  coverImage  String?
  visibility  CollectionVisibility @default(PRIVATE)
  itemsCount  Int                  @default(0)
  viewsCount  Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  ownerId String
  owner   User   @relation("UserCollections", fields: [ownerId], references: [id], onDelete: Cascade)

  items   CollectionItem[]
  members CollectionMember[]
  savedBy SavedCollection[]

  @@index([ownerId])
  @@index([visibility])
}

model CollectionMember {
  id           String                 @id @default(uuid())
  collectionId String
  collection   Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         CollectionRole         @default(VIEWER)
  status       CollectionMemberStatus @default(ACCEPTED)
  createdAt    DateTime               @default(now())

  @@unique([collectionId, userId])
  @@index([userId])
}

model CollectionItem {
  id           String             @id @default(uuid())
  collectionId String
  collection   Collection         @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  type         CollectionItemType

  // For QUIZ_TEMPLATE
  quizId String?
  quiz   Quiz?   @relation("QuizTemplate", fields: [quizId], references: [id], onDelete: Cascade)

  // For QUESTION_BANK
  bankId String?
  bank   Quiz?   @relation("QuestionBank", fields: [bankId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedCollection {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  savedAt      DateTime   @default(now())

  @@unique([userId, collectionId])
  @@index([userId])
}
