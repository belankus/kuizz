// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SUPERADMIN
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String?
  password     String?
  role         Role         @default(USER)
  provider     String?
  providerId   String?
  refreshToken String?
  avatar       Json?
  quizzes      Quiz[]
  gameHistory  GamePlayer[] @relation("UserGameHistory")
  createdAt    DateTime     @default(now())
}

model Quiz {
  id           String        @id @default(uuid())
  title        String
  description  String?
  ownerId      String?
  owner        User?         @relation(fields: [ownerId], references: [id])
  questions    Question[]
  createdAt    DateTime      @default(now())
  gameSessions GameSession[] @relation("QuizToGameSessions") // relation to GameSession
}

model Question {
  id        String   @id @default(uuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text      String
  timeLimit Int // seconds
  order     Int
  mediaUrl  String?
  options   Option[]
}

model Option {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
}

model GameSession {
  id             String       @id @default(uuid())
  hostId         String?
  quizId         String?
  quiz           Quiz?        @relation("QuizToGameSessions", fields: [quizId], references: [id], onDelete: SetNull)
  title          String // snapshot quiz title
  questions      Json // snapshot seluruh question + options
  totalQuestions Int
  createdAt      DateTime     @default(now())
  finishedAt     DateTime?
  status         GameStatus   @default(WAITING)
  players        GamePlayer[] @relation("SessionToPlayers")

  @@index([quizId])
}

enum GameStatus {
  WAITING
  STARTED
  FINISHED
  ABORTED
}

model GamePlayer {
  id        String       @id @default(uuid())
  sessionId String
  session   GameSession  @relation("SessionToPlayers", fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?        @relation("UserGameHistory", fields: [userId], references: [id], onDelete: SetNull)
  nickname  String
  score     Int
  joinedAt  DateTime     @default(now())
  answers   GameAnswer[] @relation("PlayerToAnswers")

  @@unique([sessionId, nickname])
  @@index([sessionId])
  @@index([userId])
}

model GameAnswer {
  id               String     @id @default(uuid())
  playerId         String
  player           GamePlayer @relation("PlayerToAnswers", fields: [playerId], references: [id], onDelete: Cascade)
  questionIndex    Int
  selectedOptionId String
  isCorrect        Boolean
  responseTime     Int

  @@index([playerId])
}
